{
    "$schema": "https://unpkg.com/knip@6/schema.json",
	"entry": [
		"src/**/index.ts"
	],
    "project": [
        "**/*.{ts,tsx}"
    ],
	"ignore": [
		"src/components/ui/**"
	],
	"ignoreDependencies": [
		"@fontsource-variable/inter",
		"shadcn",
		"tailwindcss",
		"tw-animate-css",
		"@tailwindcss/typography"
	]
}
