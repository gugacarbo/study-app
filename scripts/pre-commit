#!/usr/bin/env bash
# Gate local do CASA Standard (STANDARD §3, ADR-0001) para repo sem remote/CI.
# Instalação, a partir da raiz do repo:
#   ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
# Contornar exige ato deliberado (git commit --no-verify) — e é assim que deve ser.
set -euo pipefail
exec python3 "$(git rev-parse --show-toplevel)/scripts/docs-check"
