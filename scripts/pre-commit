#!/usr/bin/env bash
# Gate local do CASA Standard (STANDARD §3) — docs-check + regras T1 no pre-commit.
# Chamado por .husky/pre-commit (husky). Sem husky: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
# Contornar exige ato deliberado (git commit --no-verify) — e é assim que deve ser.
set -euo pipefail
exec python3 "$(git rev-parse --show-toplevel)/scripts/docs-check" --staged

pnpm lint-staged
pnpx test-staged
