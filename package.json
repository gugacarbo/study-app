{
  "name": "study-app",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "wrangler:dev": "wrangler dev",
    "cf-typegen": "wrangler types",
    "build": "vite build",
    "preview": "npm run build && vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:generate:local": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "wrangler d1 migrations apply study-app-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply study-app-db --remote",
    "db:reset": "wrangler d1 migrations apply study-app-db --local --reset",
    "db:reset:prod": "wrangler d1 migrations apply study-app-db --remote --reset",
    "postinstall": "npm run cf-typegen && npm run db:migrate"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@openrouter/sdk": "^0.12.35",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/ai": "^0.21.0",
    "@tanstack/ai-client": "^0.12.0",
    "@tanstack/ai-openai": "^0.9.6",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.170.6",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.0",
    "@tanstack/react-start": "^1.168.9",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/router-plugin": "^1.168.9",
    "@tanstack/store": "^0.11.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.76.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.8.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/workers-types": "^4.20260521.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "^0.7.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.93.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
